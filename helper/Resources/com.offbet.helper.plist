<?xml version="1.0" encoding="UTF-8"?>
<!-- LaunchDaemon for the privileged helper. Registered via SMAppService on
     macOS 13+ (preferred over a hand-installed /Library/LaunchDaemons plist).
     KeepAlive + RunAtLoad so it relaunches if killed; the Watchdog re-arms
     protection state. Honestly named com.offbet.* — no Apple impersonation. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.offbet.helper</string>
    <key>BundleProgram</key>
    <string>Contents/MacOS/OffbetHelper</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.offbet.mac</string>
    </array>
    <key>StandardErrorPath</key>
    <string>/Library/Logs/OFFBET/helper.err.log</string>
    <key>StandardOutPath</key>
    <string>/Library/Logs/OFFBET/helper.out.log</string>
</dict>
</plist>
